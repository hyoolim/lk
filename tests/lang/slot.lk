include('tester.lk')
Tester.new('slot').do {

Dog := Object.new
dog := Dog.new

.test('@_type is set on new', dog@_type == Dog, True)
.test('@_type is not the parent type', dog@_type == Object, False)

obj := Object.new

.test('@name read on missing slot returns Nil', obj@name, Nil)

obj@name := 'Rex'
.test('@name := defines and assigns', obj@name, 'Rex')

obj@name = 'Max'
.test('@name = assigns to existing', obj@name, 'Max')

f := { 42 }
obj@fn := f
.test('@name returns function ref, does not call', obj@fn == f, True)

.finish
}
